# ── Required ──────────────────────────────────────────────────
# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Optional: images ──────────────────────────────────────────
# Unsplash (50 req/hr free) → https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=

# Pexels (200 req/hr free) → https://www.pexels.com/api/
# Used as fallback if Unsplash is not configured
PEXELS_API_KEY=

# ── Server ────────────────────────────────────────────────────
PORT=3000
